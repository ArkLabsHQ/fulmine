        },
        "forfeitTxs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "The partially signed forfeit txs that are gonna be submitted by the delegate when joining\nthe batch execution"
        },
        "rejectReplace": {
          "type": "boolean",
          "title": "Opt-in flag to instruct the delegate to not replace an existing delegate that includes at\nleast one VTXO included in this request"
        }
      },
      "title": "DelegateRequest is the request message for Delegate rpc"
    },
    "v1DelegateResponse": {
      "type": "object",
