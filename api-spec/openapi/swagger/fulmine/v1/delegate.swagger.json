          "type": "string",
          "title": "The delegate pubkey to include in the vtxo script"
        },
        "fee": {
          "type": "string",
          "title": "The service fee applied by the delegate"
        },
        "delegatorAddress": {
          "type": "string",
          "title": "The delegate address for the service fee, if any (wrong name, will be deprecated)"
